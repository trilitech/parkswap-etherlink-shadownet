# =============================================================================
# ParkSwap / dex-ui — copy to `.env.local` and adjust for your deployment.
# =============================================================================
#
# All `NEXT_PUBLIC_*` variables are inlined at build time. After changing them,
# restart `next dev` / rebuild before deploying.
#
# --- Chain & RPC ---
# Integer chain id, e.g. Etherlink Shadownet = 127823
# NEXT_PUBLIC_CHAIN_ID=127823
#
# JSON-RPC URL for reads (balances, pool state, quotes). Must match CHAIN_ID.
# NEXT_PUBLIC_RPC_URL=https://node.shadownet.etherlink.com
#
# Hex chain id for wallet_switchEthereumChain. If omitted, derived as 0x{hex(CHAIN_ID)}.
# NEXT_PUBLIC_CHAIN_ID_HEX=0x1f34f
#
# Shown in the header when the wallet is on this chain; also used in toasts.
# NEXT_PUBLIC_NETWORK_DISPLAY_NAME=Etherlink Shadownet Testnet
#
# `chainName` in wallet_addEthereumChain (MetaMask “network name”).
# NEXT_PUBLIC_WALLET_CHAIN_NAME=Etherlink Shadownet Testnet
#
# Native currency for wallet_addEthereumChain (not the gas token symbol on all chains — set correctly for yours).
# NEXT_PUBLIC_NATIVE_CURRENCY_NAME=XTZ
# NEXT_PUBLIC_NATIVE_CURRENCY_SYMBOL=XTZ
# NEXT_PUBLIC_NATIVE_CURRENCY_DECIMALS=18
#
# --- Block explorer (Blockscout-style paths: /tx/{hash}, /address/{addr}) ---
# NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://shadownet.explorer.etherlink.com
#
# --- Uniswap v3–compatible core (swap router, quoter, NFT manager, factory) ---
# NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=0x...
# NEXT_PUBLIC_QUOTER_V2_ADDRESS=0x...
# NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=0x...
# NEXT_PUBLIC_V3_FACTORY_ADDRESS=0x...
#
# --- Featured / default tokens (swap & liquidity presets) ---
# NEXT_PUBLIC_TOKEN_USDC_ADDRESS=0x...
# NEXT_PUBLIC_TOKEN_USDC_DECIMALS=6
# NEXT_PUBLIC_TOKEN_USDC_SYMBOL=USDC
# NEXT_PUBLIC_TOKEN_USDC_NAME=USD Coin
#
# NEXT_PUBLIC_TOKEN_XU3O8_ADDRESS=0x...
# NEXT_PUBLIC_TOKEN_XU3O8_DECIMALS=18
# NEXT_PUBLIC_TOKEN_XU3O8_SYMBOL=xU3O8
# NEXT_PUBLIC_TOKEN_XU3O8_NAME=xU3O8
#
# VNXAU (or rename symbols via env on another deployment)
# NEXT_PUBLIC_TOKEN_VNXAU_ADDRESS=0x...
# Legacy alias still supported:
# NEXT_PUBLIC_VNXAU_TOKEN_ADDRESS=0x...
# NEXT_PUBLIC_TOKEN_VNXAU_DECIMALS=18
# NEXT_PUBLIC_TOKEN_VNXAU_SYMBOL=VNXAU
# NEXT_PUBLIC_TOKEN_VNXAU_NAME=VNX Gold
#
# --- Pinned pool (Pool tab price + fast path in resolvePoolAddress for that pair) ---
# Primary featured pool used elsewhere in the app.
# NEXT_PUBLIC_FEATURED_POOL_ADDRESS=0x...
# Alias:
# NEXT_PUBLIC_DASHBOARD_POOL_ADDRESS=0x...
#
# Optional explicit pool cards for the Pool page.
# NEXT_PUBLIC_POOL_USDC_XU3O8_ADDRESS=0x...
# NEXT_PUBLIC_POOL_USDC_VNXAU_ADDRESS=0x...
#
# --- Faucet server env (do not prefix with NEXT_PUBLIC_) ---
# The faucet API route runs server-side. It uses FAUCET_PRIVATE_KEY first,
# then falls back to PRIVATE_KEY if FAUCET_PRIVATE_KEY is unset.
# PRIVATE_KEY=0x...
# Optional explicit faucet key:
# FAUCET_PRIVATE_KEY=0x...
#
# --- Optional: canonical site origin (no trailing slash) ---
# NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com
